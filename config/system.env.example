# cheap-coder configuration. Copy to config/system.env and fill in.
# NEVER commit config/system.env - it holds your key. (.gitignore blocks it.)

# --- Executor model (the CHEAP one that does the grinding) ------------------
# ANY Anthropic-compatible endpoint works - Claude Code just needs one. Pick your
# cheap model and drop its base URL + key + model string here. Examples:
#   MiniMax : EXECUTOR_BASE_URL="https://api.minimax.io/anthropic"  MODEL="MiniMax-M2"
#   DeepSeek: EXECUTOR_BASE_URL="https://api.deepseek.com/anthropic" MODEL="deepseek-chat"
#   GLM/Zhipu, Qwen, Kimi, etc. all publish Anthropic-compatible endpoints too.
EXECUTOR_BASE_URL="https://api.minimax.io/anthropic"
EXECUTOR_API_KEY=""                      # your cheap-model key - REQUIRED
EXECUTOR_MODEL="MiniMax-M2"              # the cheap coding model
EXECUTOR_SMALL_MODEL="MiniMax-M2"        # background/small calls

# --- Planner + Reviewer model (the SMART one - Claude) ----------------------
# Leave blank to use your normal Claude Code login (default). Only set these to
# force a specific endpoint for the planner/reviewer.
PLANNER_MODEL=""                         # blank = your default Claude

# --- Guardrails (what keeps a cheap model from wrecking things) -------------
BUDGET_MAX_TASKS="20"                    # executor stops after this many tasks
REQUIRE_TESTS="1"                        # 1 = every task MUST have a test command
REQUIRE_GREEN="1"                        # 1 = tests must pass before a task commits
PROTECTED_FILE=".protected"              # glob list the executor may never touch
EXECUTOR_BRANCH_PREFIX="exec/"           # executor always works on its own branch
